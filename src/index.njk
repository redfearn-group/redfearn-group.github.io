      <div class="card">
        <div class="card-icon"><svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12 L16 5 L27 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="6" y="12" width="20" height="13" stroke="currentColor" stroke-width="1.6"/>
          <line x1="11" y1="14.5" x2="11" y2="22.5" stroke="currentColor" stroke-width="1.6"/>
