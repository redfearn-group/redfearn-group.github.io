          <path d="M5 25 L12 17 L18 21 L27 8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="5" cy="25" r="1.8" fill="currentColor"/>
          <circle cx="12" cy="17" r="1.8" fill="currentColor"/>
          <circle cx="18" cy="21" r="1.8" fill="currentColor"/>
          <circle cx="27" cy="8" r="2.4" fill="currentColor"/>
        </svg></div>
