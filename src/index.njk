          <line x1="7" y1="24" x2="16" y2="19" stroke="currentColor" stroke-width="1.6"/>
          <line x1="25" y1="24" x2="16" y2="19" stroke="currentColor" stroke-width="1.6"/>
          <line x1="7" y1="24" x2="25" y2="24" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="16" cy="7" r="2.6" fill="currentColor"/>
          <circle cx="16" cy="19" r="2.2" fill="none" stroke="currentColor" stroke-width="1.6"/>
          <circle cx="7" cy="24" r="2.6" fill="currentColor"/>
          <circle cx="25" cy="24" r="2.6" fill="currentColor"/>
        </svg></div>
