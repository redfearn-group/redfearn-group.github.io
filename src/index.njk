        <h3>Federal &amp; Enterprise Advisory</h3><p class="small">Security and compliance-heavy environments, by choice. Active DoD Secret clearance.</p>
      </div>
    </div>
  </div>
</section>

{% if collections.posts.length %}
<section class="section section--border-top">
  <div class="wrap">
    <h2 class="section-label">Latest Insights</h2>
    {% for post in collections.posts | limit(3) %}
    <a href="{{ post.url }}" class="post-list__item" style="display: flex;">
      <h3 class="post-list__title">{{ post.data.title }}</h3>
      <span class="post-list__meta">{{ post.data.date | readableDate }}</span>
    </a>
    {% endfor %}
    <p style="margin-top: 2rem;"><a href="/insights/" class="btn btn-ghost">Read all insights &rarr;</a></p>
  </div>
</section>
{% endif %}
