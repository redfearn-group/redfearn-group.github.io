      </div>
      <div class="card">
        <div class="card-icon"><svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 16a10 10 0 0 1 17-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M26 16a10 10 0 0 1-17 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <path d="M23 9 L24.5 5 L27.5 8.5 Z" fill="currentColor"/>
          <path d="M9 23 L7.5 27 L4.5 23.5 Z" fill="currentColor"/>
        </svg></div>
